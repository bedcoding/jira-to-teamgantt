{
  "manifest_version": 3,
  "name": "Jira to TeamGantt",
  "version": "0.1.6",
  "description": "Jira와 TeamGantt의 내 작업을 좌우로 나열해 누락을 시각화하고 단축키 한 번으로 TeamGantt에 자동 입력합니다.",
  "permissions": ["storage", "unlimitedStorage", "tabs", "activeTab", "scripting", "downloads", "sidePanel"],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://app.teamgantt.com/*",
    "https://api.teamgantt.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Jira to TeamGantt",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "inject-next-task": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "TeamGantt 활성 입력창에 다음 Jira 작업 주입"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.atlassian.net/issues*"],
      "js": ["content/jira.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.atlassian.net/*"],
      "js": ["content/jira-fetch-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.atlassian.net/*"],
      "js": ["content/jira-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://app.teamgantt.com/*"],
      "js": ["content/teamgantt-fetch-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://app.teamgantt.com/*"],
      "js": ["content/teamgantt-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
